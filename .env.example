# Copy to .env and fill in. Anvil forks this RPC endpoint at the pinned
# block below - never "latest" (design doc section 5.3), so tests stay
# deterministic. Default below is a free, keyless public Ethereum mainnet
# archive RPC (verified working) - swap for your own Alchemy/Infura
# endpoint if you hit rate limits.
ANVIL_FORK_URL=https://eth-mainnet.public.blastapi.io
ANVIL_FORK_BLOCK=18000000

# ingestion-ws needs a real wss:// endpoint per network - the free public RPCs
# used elsewhere in this project (application.yaml) are HTTPS-only, and
# eth_subscribe needs a websocket. Fill in whichever networks you're actually
# subscribing contracts on; any left unset keep the checked-in placeholder
# and ingestion-ws will fail to connect for that network only (the others
# are unaffected). Picked up automatically by `./gradlew :ingestion-ws:run`.
# WS_RPC_URL_ETHEREUM=wss://eth-mainnet.g.alchemy.com/v2/your-api-key
# WS_RPC_URL_ARBITRUM=wss://arb-mainnet.g.alchemy.com/v2/your-api-key
# WS_RPC_URL_BASE=wss://base-mainnet.g.alchemy.com/v2/your-api-key
# WS_RPC_URL_OPTIMISM=wss://opt-mainnet.g.alchemy.com/v2/your-api-key
# WS_RPC_URL_POLYGON=wss://polygon-mainnet.g.alchemy.com/v2/your-api-key
